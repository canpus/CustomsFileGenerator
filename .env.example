# 报关资料自动生成系统 — 环境变量模板
# 使用说明：复制本文件为 .env，填入真实值
# 注意：.env 绝不提交到 Git！

# ========== 数据库配置 ==========
DATABASE_PATH=data/customs.db

# ========== 日志级别 ==========
# 可选值：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# ========== API 密钥（预留） ==========
# 如果后续接入 LLM 或翻译 API，在此配置
# DEEPSEEK_API_KEY=
# OPENAI_API_KEY=

# ========== 调试选项 ==========
# 设为 true 时启用详细日志输出
DEBUG=false
